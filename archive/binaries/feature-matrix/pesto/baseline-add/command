cutechess-cli \
  -engine cmd=./oopsmate_pesto_base name="base" \
  -engine cmd=./oopsmate_pesto_add-aspiration-windows name="aspiration-windows" \
  -engine cmd=./oopsmate_pesto_add-check-extensions name="check-extensions" \
  -engine cmd=./oopsmate_pesto_add-futility name="futility" \
  -engine cmd=./oopsmate_pesto_add-history-heuristic name="history-heuristic" \
  -engine cmd=./oopsmate_pesto_add-iid name="iid" \
  -engine cmd=./oopsmate_pesto_add-killer-moves name="killer-moves" \
  -engine cmd=./oopsmate_pesto_add-lmr name="lmr" \
  -engine cmd=./oopsmate_pesto_add-null-move name="null-move" \
  -engine cmd=./oopsmate_pesto_add-probcut name="probcut" \
  -engine cmd=./oopsmate_pesto_add-pvs name="pvs" \
  -engine cmd=./oopsmate_pesto_add-razoring name="razoring" \
  -engine cmd=./oopsmate_pesto_add-reverse-futility name="reverse-futility" \
  -engine cmd=./oopsmate_pesto_add-see name="see" \
  -engine cmd=./oopsmate_pesto_add-singular-extensions name="singular-extensions" \
  -engine cmd=./oopsmate_pesto_add-tt-cutoffs name="tt-cutoffs" \
  -engine cmd=./oopsmate_pesto_add-tt-move-ordering name="tt-move-ordering" \
  -each proto=uci tc=8+0.08 option.Hash=64 \
  -rounds 10 \
  -openings file=Modern.pgn format=pgn order=random plies=16 \
  -pgnout pesto_feature_matrix_rr.pgn \
  -concurrency 8 \
  -recover \
  -repeat \
  -draw movenumber=40 movecount=8 score=10 \
  -resign movecount=3 score=700 \
  -tournament round-robin
